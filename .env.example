# ─── Core ────────────────────────────────────────────────────────────────────
PORT=8787
API_BASE_URL=https://api.rendley.com/v1
APP_BASE_URL=https://app.rendley.com

# ─── Browser driver ──────────────────────────────────────────────────────────
# local = in-process Playwright Chrome; remote = Cloudflare browser worker.
BROWSER_MODE=local
HEADLESS=true
USE_CHROME_CHANNEL=true
CPU_ONLY=false
# BROWSER_WORKER_URL=https://remote-chromium.com
# BROWSER_WORKER_TOKEN=

# ─── Logging & telemetry ─────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_SERVICE_NAME=rendley-mcp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# ─── Security ────────────────────────────────────────────────────────────────
# CORS_ORIGINS=https://app.example.com
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=240

# ─── OAuth ───────────────────────────────────────────────────────────────────
MCP_PUBLIC_URL=https://mcp.rendley.com
# OAUTH_SCOPES=rendley:read,rendley:write
# OPENAI_APPS_CHALLENGE_TOKEN=

# ─── Capacity tuning (optional) ──────────────────────────────────────────────
# QUEUE_CONCURRENCY=120
# QUEUE_MAX_QUEUED=1000
# BROWSER_RECYCLE_AFTER=8
# AGENT_TIMEOUT_MS=480000
# CHROMIUM_JS_HEAP_MB=512
