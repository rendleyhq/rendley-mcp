{
  "name": "mcp.rendley.com",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "dev": "LOG_PRETTY=true bun --preload ./src/instrumentation.ts --watch src/index.ts",
    "start": "bun --preload ./src/instrumentation.ts src/index.ts",
    "typecheck": "tsc --noEmit",
    "tunnel": "cloudflared tunnel --url http://localhost:8787 --hostname rendley-mcp",
    "postinstall": "test \"$PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD\" = \"1\" || playwright install chromium || echo 'Playwright chromium install failed — set USE_CHROME_CHANNEL=true and use system Chrome, or retry \"bunx playwright install chromium\".'"
  },
  "dependencies": {
    "@hono/otel": "0.5.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.206.0",
    "@opentelemetry/auto-instrumentations-node": "0.65.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.206.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.206.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.206.0",
    "@opentelemetry/resources": "2.1.0",
    "@opentelemetry/sdk-logs": "0.206.0",
    "@opentelemetry/sdk-metrics": "2.1.0",
    "@opentelemetry/sdk-node": "0.206.0",
    "hono": "^4.12.14",
    "p-queue": "^9.1.2",
    "pino": "^9.5.0",
    "playwright": "1.59.1",
    "xxhashjs": "^0.2.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3"
  }
}
